{
  "name": "itunes2discord",
  "version": "1.2.1",
  "description": "Shows your iTunes/Music now-playing track as Discord Rich Presence",
  "main": "src/main.js",
  "author": "Mak Siminski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MackSiminski53/itunes2discord.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.yourname.itunes2discord",
    "productName": "iTunes2Discord",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.music",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "iTunes2Discord needs permission to check what's currently playing in Music so it can update your Discord status.",
        "LSUIElement": true
      }
    },
    "publish": {
      "provider": "github",
      "owner": "MackSiminski53",
      "repo": "itunes2discord"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/get-track.ps1",
      "src/get-track.applescript"
    ]
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "electron-updater": "^6.3.0",
    "electron-log": "^5.1.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
