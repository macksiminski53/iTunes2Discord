{
  "name": "musictodiscord",
  "version": "1.5.1",
  "description": "Shows your Apple Music or iTunes now-playing track as Discord Rich Presence",
  "main": "src/main.js",
  "author": "Mak Siminski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MackSiminski53/itunes2discord.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "publish": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.yourname.musictodiscord",
    "productName": "MusicToDiscord",
    "win": {
      "target": "nsis",
      "icon": "assets/icon-source.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "MackSiminski53",
      "repo": "itunes2discord"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/get-track.ps1"
    ],
    "extraResources": [
      {
        "from": "smtc-helper/publish",
        "to": "smtc-helper"
      }
    ]
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "electron-updater": "^6.3.0",
    "electron-log": "^5.1.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
